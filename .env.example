DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-production-secret
DJANGO_ALLOWED_HOSTS=your-domain.example.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.example.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.example.com
FRONTEND_URL=https://your-frontend-domain.example.com

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
JWT_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
MAIL_USERNAME=your-mailbox@example.com
MAIL_APP_PASSWORD=replace-with-mail-app-password
